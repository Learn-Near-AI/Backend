# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated origins, or * for allow-all (development only)
# Production: set specific origins e.g. https://your-frontend.com,https://app.example.com
CORS_ORIGIN=*

# NEAR CLI Deployment (required for deploy/call/view endpoints)
NEAR_ACCOUNT_ID=your-account.testnet
NEAR_PRIVATE_KEY=ed25519:your-private-key-here
NEAR_NETWORK=testnet
