# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# NEAR Blockchain (required for deploy, call, view)
NEAR_ACCOUNT_ID=your-account.testnet
NEAR_PRIVATE_KEY=ed25519:your-private-key
NEAR_NETWORK=testnet

# Optional: Override RPC URL (defaults based on NEAR_NETWORK)
# NEAR_NODE_URL=https://rpc.testnet.fastnear.com

# Optional: Override Explorer URL (defaults based on NEAR_NETWORK)
# NEAR_EXPLORER_URL=https://explorer.testnet.near.org

# CORS - comma-separated origins, or * for all
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
RATE_LIMIT_COMPILE_MAX=5
RATE_LIMIT_DEPLOY_MAX=10

# Request limits
MAX_JSON_BODY_SIZE=10mb
MAX_CODE_LENGTH=500000
MAX_WASM_BASE64_LENGTH=6000000

# Logging
LOG_LEVEL=info

# Test script (scripts/test-wsl-endpoints.sh) - backend URL for endpoint tests
BACKEND_URL=http://localhost:3001
